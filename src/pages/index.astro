---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import Button from "../components/Button.astro";
import MenuSection from "../components/MenuSection.astro";
---

<Layout title="Inicio" description="Asador El Pelirón">
	<Hero
		title="BIENVENIDOS A NUESTRA CASA"
		images={[
			"../images/hero_pollo.png",
			"../images/hero_croquetas.png",
			"../images/hero_tortilla.png",
		]}
	>
		<Button href="/menu">Ver Carta</Button>
	</Hero>

	<div class="section-alt section-spacer">
		<MenuSection title="¿Dónde estamos?" id="donde-estamos">
			<div class="editorial-copy">
				<p class="intro-p">
					Puedes encontrarnos en la Avenida Ronda del Pelirón 49, o haz
					clic en el mapa para obtener indicaciones.
				</p>
				<div class="map-wrapper">
					<iframe
						src="https://www.google.com/maps?q=Av.+Ronda+del+Pelirón,+49,+Jerez+de+la+Frontera&output=embed"
						width="100%"
						height="450"
						style="border:0;"
						allowfullscreen=""
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						title="Ubicación Asador El Pelirón"></iframe>
				</div>
			</div>
		</MenuSection>
	</div>

</Layout>

<style>
	.ml-4 {
		margin-left: 1rem;
	}

	.mt-8 {
		margin-top: 2rem;
	}

	.editorial-copy {
		max-width: 600px;
		margin: 0 auto;
		text-align: center;
	}

	.intro-p {
		font: var(--body-md);
		color: var(--on-surface);
		line-height: 1.6;
		margin-bottom: 2rem;
	}

	.map-wrapper {
		width: 100%;
		border: 1px solid var(--outline-variant);
		filter: grayscale(0.4) contrast(0.9);
		transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.map-wrapper:hover {
		filter: grayscale(0) contrast(1);
		border-color: var(--primary);
	}

	.map-wrapper iframe {
		display: block;
	}

	.gallery {
		padding: 4rem 0 8rem;
	}

	.gallery-item.large {
		grid-column: 1 / 9;
	}

	.gallery-item.small {
		grid-column: 9 / 13;
		padding-top: 4rem;
	}

	.gallery-item img {
		width: 100%;
		height: auto;
		display: block;
	}

	@media (max-width: 768px) {
		.gallery-item.large,
		.gallery-item.small {
			grid-column: 1 / 13;
			padding-top: 0;
			margin-bottom: 2rem;
		}
	}
</style>
