---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import Button from "../components/Button.astro";
import MenuSection from "../components/MenuSection.astro";
---

<Layout title="Inicio">
	<Hero
		title="EL ARTE DEL FUEGO Y LA TIERRA"
		subtitle="Una oda a la cocina ancestral, donde el humo y el sarmiento dictan el ritmo de cada plato."
		images={[
			"../images/hero_pollo.png",
			"../images/hero_croquetas.png",
			"../images/hero_tortilla.png",
		]}
	>
		<Button href="/menu">Ver Carta</Button>
		<Button href="/reserva" variant="secondary" class="ml-4"
			>Reservar Mesa</Button
		>
	</Hero>

	<MenuSection title="Nuestra Propuesta" id="propuesta">
		<div class="editorial-copy">
			<p class="intro-p">
				Nuestros productos provienen de productores locales y respetan
				el ciclo natural de la tierra. La leña de encina y el sarmiento
				son los únicos elementos de cocción, preservando el sabor
				honesto del origen.
			</p>
			<div class="mt-8">
				<Button href="/historia" variant="tertiary"
					>Conoce nuestra historia</Button
				>
			</div>
		</div>
	</MenuSection>
</Layout>

<style>
	.ml-4 {
		margin-left: 1rem;
	}

	.mt-8 {
		margin-top: 2rem;
	}

	.editorial-copy {
		max-width: 600px;
	}

	.intro-p {
		font: var(--display-md);
		color: var(--on-surface);
	}

	.gallery {
		padding: 4rem 0 8rem;
	}

	.gallery-item.large {
		grid-column: 1 / 9;
	}

	.gallery-item.small {
		grid-column: 9 / 13;
		padding-top: 4rem;
	}

	.gallery-item img {
		width: 100%;
		height: auto;
		display: block;
	}

	@media (max-width: 768px) {
		.gallery-item.large,
		.gallery-item.small {
			grid-column: 1 / 13;
			padding-top: 0;
			margin-bottom: 2rem;
		}
	}
</style>
