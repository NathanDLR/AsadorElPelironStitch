---
import Layout from '../components/Layout.astro';
import MenuSection from '../components/MenuSection.astro';
import MenuItem from '../components/MenuItem.astro';
---

<Layout title="Nuestra Carta" description="Explora el sabor del fuego en nuestra carta seleccionada.">
    <div class="menu-intro container section-spacer">
        <h1 class="display-lg">NUESTRA PROPUESTA</h1>
        <p class="body-md intro-text">
            Una selección de productos honestos, tratados con respeto y expuestos al fuego directo de la encina. 
            Sin artificios, solo el origen.
        </p>
    </div>

    <MenuSection title="Entrantes" id="entrantes">
        <MenuItem 
            name="Cecina de León Selección" 
            description="Curación mínima de 18 meses, corte fino a cuchillo con aceite de oliva virgen extra de cosecha propia."
            price="18€"
        />
        <MenuItem 
            name="Puerros de la Huerta a la Llama" 
            description="Con emulsión de romesco ahumado y lascas de almendra marcona tostada."
            price="14€"
        />
        <MenuItem 
            name="Mollejas de Ternera al Sarmiento" 
            description="Crujientes por fuera y melosas por dentro, acompañadas de crema de coliflor trufada."
            price="22€"
        />
    </MenuSection>

    <MenuSection title="Carnes a la Brasa" id="carnes">
        <MenuItem 
            name="Chuleta de Vaca Vieja (1kg)" 
            description="Selección de razas autóctonas, maduración mínima de 45 días en nuestra propia cámara. Sabor intenso y textura fundente."
            price="75€"
        />
        <MenuItem 
            name="Solomillo de Ternera de Ávila" 
            description="Al fuego de encina, servido con sal de escamas y pimientos del cristal confitados."
            price="32€"
        />
        <MenuItem 
            name="Lechazo de Aranda al Horno de Leña" 
            description="Cuarto de cordero lechal asado al estilo tradicional en horno de adobe. (Encargo previo 24h)."
            price="58€"
        />
    </MenuSection>

    <MenuSection title="Postres" id="postres">
        <MenuItem 
            name="Tarta de Queso 'El Ahumado'" 
            description="Queso de oveja local con un sutil toque de humo de sarmiento y base de galleta artesana."
            price="9€"
        />
        <MenuItem 
            name="Torrija Caramelizada" 
            description="Pan de brioche artesano infusionado en leche de oveja y acompañada de helado de vainilla Bourbon."
            price="10€"
        />
    </MenuSection>

    <div class="container menu-footer section-spacer">
        <div class="terracotta-thread"></div>
        <p class="body-md footer-note">
            Todos nuestros productos son de temporada. Consulte por nuestros pescados fuera de carta, traídos diariamente de las mejores lonjas.
        </p>
    </div>
</Layout>

<style>
    .menu-intro {
        text-align: left;
        padding-top: 10rem;
    }

    .display-lg {
        font: var(--display-lg);
        margin-bottom: 2rem;
        text-transform: uppercase;
    }

    .intro-text {
        font: var(--body-lg);
        max-width: 500px;
        opacity: 0.8;
    }

    .menu-footer {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        border-top: 1px solid rgba(137, 114, 108, 0.2);
    }

    .footer-note {
        font: var(--body-md);
        max-width: 600px;
        opacity: 0.6;
        font-style: italic;
    }

    @media (max-width: 768px) {
        .display-lg {
            font-size: 3.5rem;
        }
    }
</style>
