---
const categories = [
  { name: 'Ofertas', id: 'ofertas' },
  { name: 'Pollo', id: 'pollo' },
  { name: 'Patatas', id: 'patatas' },
  { name: 'Tortillas', id: 'tortillas' },
  { name: 'Empanados', id: 'empanados' },
  { name: 'Aliños', id: 'alinos' },
  { name: 'Bebidas', id: 'bebidas' },
  { name: 'Extras', id: 'complementos' },
];
---

<nav class="category-nav">
  <div class="container nav-wrap">
    {categories.map((cat) => (
      <a href={`#${cat.id}`} class="nav-link">{cat.name}</a>
    ))}
  </div>
</nav>

<script>
  let isManualScrolling = false;
  let scrollTimeout: number;

  // Helper to update active link
  const updateActiveStates = (id: string) => {
    const navLinks = document.querySelectorAll('.nav-link');

    navLinks.forEach(link => {
      const isTarget = link.getAttribute('href') === `#${id}`;
      link.classList.toggle('active', isTarget);
      
      if (isTarget) {
        // Center the active link in the horizontal scroll bar
        const navWrap = document.querySelector('.nav-wrap');
        if (navWrap) {
          const activeLinkOffset = (link as HTMLElement).offsetLeft;
          const activeLinkWidth = (link as HTMLElement).offsetWidth;
          const navWrapWidth = (navWrap as HTMLElement).offsetWidth;
          
          navWrap.scrollTo({
            left: activeLinkOffset - (navWrapWidth / 2) + (activeLinkWidth / 2),
            behavior: 'smooth'
          });
        }
      }
    });
  };

  // Robust anchor jumping for sticky headers
  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      if (href?.startsWith('#')) {
        e.preventDefault();
        const targetId = href.substring(1);
        const targetElement = document.getElementById(targetId);
        
        if (targetElement) {
          // Immediately set active state and lock the observer
          isManualScrolling = true;
          updateActiveStates(targetId);

          // Clear any existing timeout
          if (scrollTimeout) clearTimeout(scrollTimeout);


          requestAnimationFrame(() => {
            const headerOffset = window.innerWidth <= 768 ? 90 : 120;
            const elementPosition = targetElement.getBoundingClientRect().top;
            const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

            window.scrollTo({
              top: offsetPosition,
              behavior: 'smooth'
            });

            history.pushState(null, '', href);

            // Re-enable observer after smooth scroll completes
            scrollTimeout = window.setTimeout(endManualScroll, 1000);
          });
        }
      }
    });
  });



  // ScrollSpy logic
  const observerOptions = {
    root: null,
    rootMargin: '-15% 0px -80% 0px', // Precise zone near top
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    if (isManualScrolling) return;

    // Collect all intersecting targets and find the one closest to the top
    const intersecting = entries.filter(e => e.isIntersecting);
    if (intersecting.length > 0) {
      // Find the best target (closest to top margin)
      const bestTarget = intersecting.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)[0];
      updateActiveStates(bestTarget.target.id);
    }
  }, observerOptions);

  // Function to re-sync after manual scrolls or layout changes
  const syncActiveState = () => {
    const targets = categories.map(id => document.getElementById(id)).filter(el => el !== null) as HTMLElement[];
    const visible = targets
      .map(el => ({ id: el.id, rect: el.getBoundingClientRect() }))
      .filter(item => item.rect.top < window.innerHeight * 0.3 && item.rect.bottom > 0)
      .sort((a, b) => Math.abs(a.rect.top) - Math.abs(b.rect.top));

    if (visible.length > 0) {
      updateActiveStates(visible[0].id);
    }
  };

  // Re-enable observer and re-sync
  const endManualScroll = () => {
    isManualScrolling = false;
    syncActiveState();
  };

  // Targets to observe
  const categories = ['ofertas', 'pollo', 'patatas', 'tortillas', 'empanados', 'alinos', 'bebidas', 'complementos'];
  categories.forEach(id => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

  // Also link the timeout back to the helper
  // (We'll update the click handler to use endManualScroll)
</script>





<style>

  .category-nav {
    position: sticky;
    top: 0;
    background: rgba(252, 249, 244, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 100;
    border-bottom: 1px solid rgba(137, 114, 108, 0.15);
    padding: 1.25rem 0;
    transition: all 0.3s ease;
  }

  .nav-wrap {
    display: flex;
    overflow-x: auto;
    gap: 2.5rem;
    white-space: nowrap;
    scrollbar-width: none; /* Hide scrollbar for Firefox */
    justify-content: center;
    -webkit-overflow-scrolling: touch;
    overflow-y: hidden;
    touch-action: pan-x;
  }


  .nav-wrap::-webkit-scrollbar {
    display: none; /* Hide scrollbar for Chrome/Safari */
  }

  .nav-link {
    font: var(--label-md);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--on-surface);
    opacity: 0.5;
    letter-spacing: 0.15em;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link.active {
    opacity: 1;
    color: var(--primary);
  }

  @media (hover: hover) {
    .nav-link:hover {
      opacity: 1;
      color: var(--primary);
    }
  }

  /* Active state indicator */
  .nav-link::after {


    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--primary);
    transition: width 0.3s ease;
  }

  .nav-link.active::after {
    width: 100%;
  }

  @media (hover: hover) {
    .nav-link:hover::after {
      width: 100%;
    }
  }



  @media (max-width: 768px) {
    .category-nav {
      padding: 1rem 0;
    }
    
    .nav-wrap {
      justify-content: flex-start;
      gap: 2rem;
      padding: 0 0.5rem; /* Small extra padding for the scroll container */
    }

    .nav-link {
      font-size: 0.7rem;
    }
  }
</style>
