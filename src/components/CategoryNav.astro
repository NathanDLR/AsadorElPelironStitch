---
const categories = [
  { name: 'Ofertas', id: 'ofertas' },
  { name: 'Pollo', id: 'pollo' },
  { name: 'Patatas', id: 'patatas' },
  { name: 'Tortillas', id: 'tortillas' },
  { name: 'Empanados', id: 'empanados' },
  { name: 'Aliños', id: 'alinos' },
  { name: 'Bebidas', id: 'bebidas' },
  { name: 'Extras', id: 'complementos' },
];
---

<nav class="category-nav">
  <div class="container nav-wrap">
    {categories.map((cat) => (
      <a href={`#${cat.id}`} class="nav-link">{cat.name}</a>
    ))}
  </div>
</nav>

<script>
  /**
   * Tab Switching Logic for Single-Card Menu
   */
  const switchCategory = (targetId: string) => {
    // 1. Update Menu Cards Visibility
    const cards = document.querySelectorAll('.menu-card');
    let targetFound = false;

    cards.forEach(card => {
      const isActive = card.id === targetId;
      card.classList.toggle('active', isActive);
      if (isActive) targetFound = true;
    });

    // Default to 'ofertas' if target not found (fallback)
    if (!targetFound && targetId !== 'ofertas') {
       console.warn(`Category "${targetId}" not found, falling back to "ofertas"`);
       switchCategory('ofertas');
       return;
    }

    // 2. Update Nav Link Active States
    const navLinks = document.querySelectorAll('.nav-link');
    navLinks.forEach(link => {
      const linkId = link.getAttribute('href')?.replace('#', '');
      const isActive = linkId === targetId;
      link.classList.toggle('active', isActive);
      
      if (isActive) {
        // Center the active link in the horizontal scroll bar
        const navWrap = document.querySelector('.nav-wrap');
        if (navWrap) {
          const activeLinkOffset = (link as HTMLElement).offsetLeft;
          const activeLinkWidth = (link as HTMLElement).offsetWidth;
          const navWrapWidth = (navWrap as HTMLElement).offsetWidth;
          
          navWrap.scrollTo({
            left: activeLinkOffset - (navWrapWidth / 2) + (activeLinkWidth / 2),
            behavior: 'smooth'
          });
        }
      }
    });

    // 3. Reset scroll position to top of the menu area
    const navBar = document.querySelector('.category-nav');
    if (navBar) {
        const topPos = navBar.getBoundingClientRect().top + window.pageYOffset;
        window.scrollTo({
            top: topPos - 80,
            behavior: 'smooth'
        });
    }
  };

  const setupNav = () => {
    // Click Handlers
    document.querySelectorAll('.nav-link').forEach(link => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (href?.startsWith('#')) {
          e.preventDefault();
          const targetId = href.substring(1);
          switchCategory(targetId);
          history.pushState(null, '', href);
        }
      });
    });

    // Handle Initial Selection
    const handleInitialLoad = () => {
      const hash = window.location.hash.replace('#', '');
      if (hash) {
        switchCategory(hash);
      } else {
        switchCategory('ofertas');
      }
    };

    handleInitialLoad();
  };

  // Run on initial load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupNav);
  } else {
    setupNav();
  }

  // Handle Back/Forward buttons
  window.addEventListener('popstate', () => {
    const hash = window.location.hash.replace('#', '');
    switchCategory(hash || 'ofertas');
  });
</script>







<style>

  .category-nav {
    position: sticky;
    top: 0;
    background: rgba(252, 249, 244, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 100;
    border-bottom: 1px solid rgba(137, 114, 108, 0.15);
    padding: 1.25rem 0;
    /* Removed transition: all to prevent jitter on mobile layout shifts */
    contain: layout;
    will-change: transform;
  }


  .nav-wrap {
    display: flex;
    overflow-x: auto;
    gap: 2.5rem;
    white-space: nowrap;
    scrollbar-width: none; /* Hide scrollbar for Firefox */
    justify-content: center;
    -webkit-overflow-scrolling: touch;
    overflow-y: hidden;
    touch-action: pan-x;
  }


  .nav-wrap::-webkit-scrollbar {
    display: none; /* Hide scrollbar for Chrome/Safari */
  }

  .nav-link {
    font: var(--label-md);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--on-surface);
    opacity: 0.5;
    letter-spacing: 0.15em;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link.active {
    opacity: 1;
    color: var(--primary);
  }

  @media (hover: hover) {
    .nav-link:hover {
      opacity: 1;
      color: var(--primary);
    }
  }

  /* Active state indicator */
  .nav-link::after {


    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--primary);
    transition: width 0.3s ease;
  }

  .nav-link.active::after {
    width: 100%;
  }

  @media (hover: hover) {
    .nav-link:hover::after {
      width: 100%;
    }
  }



  @media (max-width: 768px) {
    .category-nav {
      padding: 1rem 0;
    }
    
    .nav-wrap {
      justify-content: flex-start;
      gap: 2rem;
      padding: 0 0.5rem; /* Small extra padding for the scroll container */
    }

    .nav-link {
      font-size: 0.7rem;
    }
  }
</style>
