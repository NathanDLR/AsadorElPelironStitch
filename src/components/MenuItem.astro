---
interface Props {
  name: string;
  description: string;
  price: string;
}

const { name, description, price } = Astro.props;
---

<div class="menu-item">
    <div class="item-header">
        <h3 class="item-name">{name}</h3>
        <span class="item-price">{price}</span>
    </div>
    <p class="item-description">{description}</p>
</div>

<style>
    .menu-item {
        margin-bottom: 3.5rem;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .item-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .item-name {
        font: var(--title-md);
        color: var(--on-surface);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .item-price {
        font: var(--title-sm);
        color: var(--primary);
    }

    .item-description {
        font: var(--body-sm);
        color: var(--on-surface);
        opacity: 0.6;
        max-width: 500px;
    }

    @media (max-width: 600px) {
        .menu-item {
            margin-bottom: 2.5rem;
        }
    }
</style>
