---
interface Props {
  name: string;
  description: string | string[];
  price: string;
  variant?: 'standard' | 'featured';
}

const { name, description, price, variant = 'standard' } = Astro.props;
const isArray = Array.isArray(description);
---

<div class:list={["menu-item", variant]}>

    <div class="item-header">
        <h3 class="item-name">{name}</h3>
        <span class="item-price">{price}</span>
    </div>
    {isArray ? (
        <ul class="item-description-list">
            {(description as string[]).map(line => (
                <li>{line}</li>
            ))}
        </ul>
    ) : (
        <p class="item-description">{description}</p>
    )}
</div>


<style>
    .menu-item {
        margin-bottom: 0; /* Handled by grid gap */
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 2rem 1.5rem;
        transition: all 0.4s cubic-bezier(0.2, 1, 0.3, 1);
        border: 1px solid transparent;
        border-radius: 8px;
    }

    .menu-item:hover {
        transform: translateY(-6px);
        background: white;
        box-shadow: 0 10px 30px rgba(45, 58, 48, 0.05);
        border-color: rgba(155, 63, 37, 0.1);
    }


    .menu-item.featured {
        background: var(--surface-container-low);
        border: 1px solid rgba(155, 63, 37, 0.1);
        padding: 2rem 1.5rem;
    }

    .menu-item.featured:hover {
        background: white;
        border-color: var(--primary);
    }




    .item-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .item-name {
        font: var(--title-md);
        color: var(--secondary); /* Forest Green names */
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 600;
    }

    .item-price {
        font: var(--title-md); /* Slightly larger price */
        color: var(--primary);
        font-weight: 700;
        letter-spacing: 0.02em;
    }


    .item-description,
    .item-description-list {
        font: var(--body-sm);
        color: var(--on-surface);
        opacity: 0.7;
        max-width: 500px;
        margin: 0;
        padding: 0;
    }

    .item-description-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .item-description-list li {
        font: var(--body-sm);
        letter-spacing: 0.02em;
        position: relative;
    }

    .featured .item-description-list li::before {
        content: "—";
        margin-right: 0.75rem;
        opacity: 0.3;
        font-weight: 300;
    }



    @media (max-width: 600px) {
        .menu-item {
            margin-bottom: 2.5rem;
        }
    }
</style>
