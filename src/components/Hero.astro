---
import Carousel from "./Carousel.astro";

interface Props {
    title: string;
    subtitle?: string;
    images?: string[];
}

const {
    title,
    subtitle,
    images = [
        "../images/hero_pollo.png",
        "../images/hero_croquetas.png",
        "../images/hero_tortilla.png",
    ],
} = Astro.props;
---

<section class="hero-section section-alt">
    <div class="container asymmetric-grid">
        <div class="hero-text">
            <h1 class="display-lg">{title}</h1>
            {subtitle && <p class="body-md subtitle">{subtitle}</p>}
        </div>
        <div class="hero-image">
            <Carousel images={images} height="500px" />
        </div>
        <div class="cta-group">
            <slot />
        </div>
    </div>

</section>


<style>
    .hero-section {
        padding: 5rem 0 8rem;
        overflow: hidden;
        border-bottom: 1px solid var(--outline-variant);
    }


    .asymmetric-grid {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 4rem;
    }

    .display-lg {
        font: var(--display-lg);
        margin-bottom: 2rem;
        text-transform: uppercase;
        max-width: 900px;
        color: var(--secondary); /* Forest Green for main heading */
    }


    .hero-text {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        z-index: 2;
    }

    .subtitle {
        font: var(--body-md);
        margin-bottom: 2.5rem;
        opacity: 0.8;
        font-style: italic;
        max-width: 600px;
    }

    .hero-image {
        width: 100%;
        max-width: 1000px;
        position: relative;
    }

    @media (max-width: 768px) {
        .hero-section {
            padding: 4rem 0;
        }

        .asymmetric-grid {
            gap: 3rem;
        }

        .display-lg {
            font-size: 3rem;
        }

        .hero-image {
            max-width: 100%;
        }
    }
</style>
