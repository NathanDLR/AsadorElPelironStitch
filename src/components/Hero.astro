---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
}

const { title, subtitle, image = 'https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&q=80&w=2000' } = Astro.props;
---

<section class="hero-section">
    <div class="container asymmetric-grid">
        <div class="hero-text">
            <h1 class="display-lg">{title}</h1>
            {subtitle && <p class="body-md subtitle">{subtitle}</p>}
            <div class="cta-group">
                <slot />
            </div>
        </div>
        <div class="hero-image">
            <img src={image} alt="Asador Hero Image" />
        </div>
    </div>
</section>

<style>
    .hero-section {
        padding: 8rem 0;
        overflow: hidden;
    }

    .display-lg {
        font-size: 5rem;
        line-height: 1;
        margin-bottom: 2rem;
        max-width: 800px;
    }

    .hero-text {
        grid-column: 1 / 8;
        display: flex;
        flex-direction: column;
        justify-content: center;
        z-index: 2;
    }

    .subtitle {
        margin-bottom: 3rem;
        max-width: 450px;
        opacity: 0.8;
    }

    .hero-image {
        grid-column: 7 / 13;
        position: relative;
    }

    .hero-image img {
        width: 100%;
        height: 600px;
        object-fit: cover;
        box-shadow: 40px 40px 0 var(--surface-container);
    }

    @media (max-width: 768px) {
        .hero-text {
            grid-column: 1 / 13;
            margin-bottom: 4rem;
        }

        .hero-image {
            grid-column: 1 / 13;
        }

        .display-lg {
            font-size: 3.5rem;
        }
    }
</style>
