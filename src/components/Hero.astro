---
import Carousel from './Carousel.astro';

interface Props {
    title: string;
    subtitle?: string;
    images?: string[];
}

const {
    title,
    subtitle,
    images = [
        "https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&q=80&w=2000",
        "https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&q=80&w=2000",
        "https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&q=80&w=2000"
    ],
} = Astro.props;
---

<section class="hero-section">
    <div class="container asymmetric-grid">
        <div class="hero-text">
            <h1 class="display-lg">{title}</h1>
            {subtitle && <p class="body-md subtitle">{subtitle}</p>}
            <div class="cta-group">
                <slot />
            </div>
        </div>
        <div class="hero-image">
            <Carousel images={images} height="500px" />
        </div>
    </div>
</section>

<style>
    .hero-section {
        padding: 8rem 0;
        overflow: hidden;
    }

    .asymmetric-grid {
        align-items: center;
    }

    .display-lg {
        font: var(--display-lg);
        margin-bottom: 2rem;
        text-transform: uppercase;
    }

    .hero-text {
        grid-column: 1 / 7;
        display: flex;
        flex-direction: column;
        justify-content: center;
        z-index: 2;
    }

    .subtitle {
        font: var(--body-md);
        margin-bottom: 3rem;
        opacity: 0.8;
        font-style: italic;
    }

    .hero-image {
        grid-column: 7 / 13;
        position: relative;
    }

    @media (max-width: 768px) {
        .hero-section {
            padding: 4rem 0;
        }

        .hero-text {
            grid-column: 1 / 13;
            margin-bottom: 4rem;
        }

        .hero-image {
            grid-column: 1 / 13;
        }

        .display-lg {
            font-size: 3.5rem;
        }
    }
</style>
