---
interface Props {
    images: string[];
    interval?: number;
    height?: string;
}

const { images, interval = 6500, height = "600px" } = Astro.props;
---

<div class="carousel" data-interval={interval} style={`--carousel-height: ${height}`}>
    <div class="carousel-inner">
        {
            images.map((image, index) => (
                <div
                    class={`carousel-item ${index === 0 ? "active" : ""}`}
                    data-index={index}
                >
                    <img
                        src={image}
                        alt={`Asador image ${index + 1}`}
                        loading={index === 0 ? "eager" : "lazy"}
                    />
                </div>
            ))
        }
    </div>
    <div class="carousel-indicators">
        {
            images.map((_, index) => (
                <button
                    class={`indicator ${index === 0 ? "active" : ""}`}
                    data-index={index}
                    aria-label={`Go to slide ${index + 1}`}
                />
            ))
        }
    </div>
    <button class="carousel-btn prev" aria-label="Previous slide">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M15 18l-6-6 6-6" />
        </svg>
    </button>
    <button class="carousel-btn next" aria-label="Next slide">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 6l6 6-6 6" />
        </svg>
    </button>
</div>

<script>
    function setupCarousel() {
        const carousels = document.querySelectorAll(".carousel");

        carousels.forEach((carousel) => {
            const items = carousel.querySelectorAll(".carousel-item");
            const indicators = carousel.querySelectorAll(".indicator");
            const interval = parseInt(
                carousel.getAttribute("data-interval") || "6500",
            );
            let currentIndex = 0;
            let timer: number;

            function showSlide(index: number) {
                items[currentIndex].classList.remove("active");
                indicators[currentIndex].classList.remove("active");

                currentIndex = index;

                items[currentIndex].classList.add("active");
                indicators[currentIndex].classList.add("active");
            }

            function nextSlide() {
                showSlide((currentIndex + 1) % items.length);
            }

            function startTimer() {
                timer = setInterval(nextSlide, interval);
            }

            function resetTimer() {
                clearInterval(timer);
                startTimer();
            }

            const prevBtn = carousel.querySelector(".prev");
            const nextBtn = carousel.querySelector(".next");

            prevBtn?.addEventListener("click", () => {
                showSlide((currentIndex - 1 + items.length) % items.length);
                resetTimer();
            });

            nextBtn?.addEventListener("click", () => {
                nextSlide();
                resetTimer();
            });

            indicators.forEach((indicator, index) => {
                indicator.addEventListener("click", () => {
                    showSlide(index);
                    resetTimer();
                });
            });

            startTimer();
        });
    }

    // Run on page load
    setupCarousel();
    // Run on view transitions if using them
    document.addEventListener("astro:after-swap", setupCarousel);
</script>

<style>
    .carousel {
        position: relative;
        width: 100%;
        height: var(--carousel-height);
        overflow: hidden;
        background-color: var(--surface-container);
    }

    .carousel-inner {
        position: relative;
        width: 100%;
        height: 100%;
    }

    .carousel-item {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: opacity 1.2s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 1;
    }

    .carousel-item.active {
        opacity: 1;
        z-index: 2;
    }

    .carousel-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .carousel-indicators {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 1rem;
        z-index: 10;
    }

    .indicator {
        width: 10px;
        height: 10px;
        border-radius: 50% !important;
        background-color: var(--on-surface);
        opacity: 0.2;
        border: none;
        cursor: pointer;
        padding: 0;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .indicator.active {
        opacity: 1;
        background-color: var(--primary);
        transform: scale(1.2);
    }

    .carousel-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(252, 249, 244, 0.4);
        backdrop-filter: blur(4px);
        color: var(--on-surface);
        border: none;
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        transition: all 0.3s ease;
        opacity: 0;
    }

    .carousel:hover .carousel-btn {
        opacity: 1;
    }

    .carousel-btn:hover {
        background: var(--bg);
        color: var(--primary);
    }

    .prev {
        left: 0;
    }

    .next {
        right: 0;
    }

    @media (max-width: 768px) {
        .carousel {
            height: 400px;
        }
    }

    @media (hover: none) {
        .carousel-btn {
            display: none;
        }
    }
</style>
