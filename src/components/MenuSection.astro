---
interface Props {
  title: string;
  id?: string;
}

const { title, id } = Astro.props;
---

<section id={id} class="section-spacer">
    <div class="container menu-section">
        <div class="section-header">
            <span class="terracotta-thread centered"></span>
            <h2 class="headline-lg centered">{title}</h2>
        </div>
        <div class="section-content">
            <slot />
        </div>
    </div>
</section>

<style>
    .menu-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3rem;
    }

    .section-header {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        text-align: center;
    }

    .headline-lg {
        font: var(--headline-lg);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--secondary); /* Unified Forest Green */
        margin: 0;
    }


    .section-content {
        width: 100%;
        max-width: 800px;
    }

    .terracotta-thread.centered {
        /* Inheriting vertical styles from global.css */
        flex-shrink: 0;
    }

    @media (max-width: 768px) {
        .menu-section {
            gap: 2rem;
        }

        .section-header {
            flex-direction: column;
            gap: 1rem;
            margin-bottom: 0.5rem;
        }
    }

</style>
